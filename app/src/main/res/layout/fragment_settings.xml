<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/watch_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/activity_horizontal_margin"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="@dimen/section_spacing">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="?attr/colorPrimary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="@dimen/section_spacing"
            android:background="@color/watch_blue" />


        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/watch_surface_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Font Size"
                        android:textColor="@color/watch_text_primary"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_scale_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="120%"
                        android:textColor="@color/watch_blue_dark"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>


                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_font_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="0.8"
                    android:valueTo="1.5"
                    android:stepSize="0.05"
                    android:value="1.2"
                    app:trackColorActive="@color/watch_blue_dark"
                    app:trackColorInactive="@color/watch_divider"
                    app:thumbColor="@color/watch_blue_dark"
                    app:tickVisible="false" />


                <androidx.cardview.widget.CardView
                    android:id="@+id/preview_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing"
                    app:cardBackgroundColor="@color/watch_surface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/content_spacing">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preview"
                            android:textColor="@color/watch_text_secondary"
                            android:textSize="@dimen/text_small"
                            android:textStyle="italic" />

                        <TextView
                            android:id="@+id/preview_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Upcoming Events"
                            android:textColor="@color/watch_text_primary"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/preview_body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Family dinner on Saturday at 6:00 PM"
                            android:textColor="@color/watch_text_secondary"
                            android:textSize="@dimen/text_body" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/preview_button"
                            style="@style/Widget.CircleEvents.Button"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginTop="12dp"
                            android:text="Sample Button"
                            android:textSize="@dimen/text_button" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/notify_favorites_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            app:cardBackgroundColor="@color/watch_surface_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Notifications"
                        android:textColor="@color/watch_text_primary"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Only notify me about events I have favorited (mandatory events always notify)."
                        android:textColor="@color/watch_text_secondary"
                        android:textSize="@dimen/text_small" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_notify_favorites"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/view_window_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:visibility="gone"
            app:cardBackgroundColor="@color/watch_surface_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Calendar View Window"
                    android:textColor="@color/watch_text_primary"
                    android:textSize="@dimen/text_card_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Controls how far ahead events are shown for everyone in this circle."
                    android:textColor="@color/watch_text_secondary"
                    android:textSize="@dimen/text_small" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.CircleEvents.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/content_spacing"
                    android:hint="Window"
                    app:endIconMode="dropdown_menu">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/viewWindowDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:editable="false"
                        android:textSize="@dimen/text_body" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <androidx.cardview.widget.CardView
            android:id="@+id/notification_lead_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:visibility="gone"
            app:cardBackgroundColor="@color/watch_surface_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reminder Lead Time"
                        android:textColor="@color/watch_text_primary"
                        android:textSize="@dimen/text_card_title"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_lead_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="At event time"
                        android:textColor="@color/watch_blue_dark"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="How far before each event everyone in this circle gets the reminder notification."
                    android:textColor="@color/watch_text_secondary"
                    android:textSize="@dimen/text_small" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_lead_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="0"
                    android:valueTo="60"
                    android:stepSize="5"
                    android:value="0"
                    app:trackColorActive="@color/watch_blue_dark"
                    app:trackColorInactive="@color/watch_divider"
                    app:thumbColor="@color/watch_blue_dark"
                    app:tickVisible="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_logout"
            style="@style/Widget.CircleEvents.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="32dp"
            android:text="Log Out"
            android:textColor="@color/watch_error"
            app:strokeColor="@color/watch_error"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

    </LinearLayout>
</ScrollView>
