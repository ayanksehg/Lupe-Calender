<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/label_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type"
        android:textColor="@color/watch_text_primary"
        android:textSize="@dimen/text_body"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/radio_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radio_activity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity"
            android:textSize="@dimen/text_body" />

        <RadioButton
            android:id="@+id/radio_food"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Food"
            android:textSize="@dimen/text_body" />

        <RadioButton
            android:id="@+id/radio_activity_food"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity with food"
            android:textSize="@dimen/text_body" />
    </RadioGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_description"
        style="@style/Widget.CircleEvents.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Description (optional)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2"
            android:gravity="top"
            android:textSize="@dimen/text_body" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_mandatory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Mandatory (always notifies everyone)"
        android:textColor="@color/watch_text_primary"
        android:textSize="@dimen/text_body" />

    <LinearLayout
        android:id="@+id/mandatory_scope_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply to"
            android:textColor="@color/watch_text_secondary"
            android:textSize="@dimen/text_small" />

        <RadioGroup
            android:id="@+id/radio_scope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radio_scope_instance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Just this event"
                android:textSize="@dimen/text_body" />

            <RadioButton
                android:id="@+id/radio_scope_forward"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This and all future events"
                android:textSize="@dimen/text_body" />

            <RadioButton
                android:id="@+id/radio_scope_series"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All events in the series"
                android:textSize="@dimen/text_body" />
        </RadioGroup>
    </LinearLayout>
</LinearLayout>
