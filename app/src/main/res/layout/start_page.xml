<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_start_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="Lupe logo"
            android:scaleType="fitCenter"
            app:srcCompat="@mipmap/ic_launcher_foreground" />

        <!-- Welcome text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/welcome_title"
            android:textAlignment="center"
            android:textColor="?attr/colorPrimary"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold" />

        <!-- Mode selection buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_start"
            style="@style/Widget.CircleEvents.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="24dp"
            android:text="Start a Circle"
            android:textSize="@dimen/text_button"
            app:icon="@drawable/ic_event_create"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_unc"
            style="@style/Widget.CircleEvents.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="20dp"
            android:text="Join a Circle"
            android:textSize="@dimen/text_button"
            app:icon="@drawable/ic_event_home"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_admin"
            style="@style/Widget.CircleEvents.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="20dp"
            android:text="Admin Login"
            android:textSize="@dimen/text_button" />

        <!-- Input fields (initially hidden) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/group_layout"
            style="@style/Widget.CircleEvents.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_spacing"
            android:hint="Circle Name"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/Group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textSize="@dimen/text_body" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/admin_layout"
            style="@style/Widget.CircleEvents.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_spacing"
            android:hint="Admin Code"
            android:visibility="gone"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/Admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textSize="@dimen/text_body" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_enter"
            style="@style/Widget.CircleEvents.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/section_spacing"
            android:text="Confirm"
            android:textSize="@dimen/text_button"
            android:visibility="gone"
            app:backgroundTint="@color/watch_blue_dark" />

    </LinearLayout>
</ScrollView>
